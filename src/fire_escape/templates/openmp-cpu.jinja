static inline float distance(Position a, Position b) {
    return std::hypotf(a.x - b.x, a.y - b.y);
}

static inline float alignment(Position a, Position b, float direction) {
    float dx = b.x - a.x;
    float dy = b.y - a.y;

    float d_abs = std::hypotf(dx, dy);

    float wx = std::cosf(direction / 360.0);
    float wy = -std::sinf(direction / 360.0);

    return (dx * wx + dy * wy) / d_abs;
}

static inline float clamp(float x, float xmin, float xmax) {
    if (x < xmin) {
        x = xmin;
    }
    if (x > xmax) {
        x = xmax;
    }
    return x;
}


static inline std::int32_t sample_discrete(RngEngine& rng, std::int32_t a, std::int32_t b) {
    std::uniform_int_distribution<std::int32_t> dist(a, b);
    return dist(rng);
}

static inline float sample_uniform(RngEngine& rng) {
    std::uniform_real_distribution<float> dist(0.0, 1.0);
    return dist(rng);
}

static inline float sample_normal(RngEngine& rng) {
    std::normal_distribution<float> dist(0.0, 1.0);
    return dist(rng);
}


static inline float normal_log_prob(float x) {
    return -(x * x + std::logf(std::numbers::pi) + std::logf(2.0)) / 2.0;
}

static inline std::int32_t sample_poisson(RngEngine& rng, float rate) {
    std::poisson_distribution<std::int32_t> dist(rate);
    return dist(rng);
}

static inline float poisson_log_prob(std::int32_t x, float rate) {
    return x * std::logf(rate) - rate - std::lgammaf(x + 1);
}

