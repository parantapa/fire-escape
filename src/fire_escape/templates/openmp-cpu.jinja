                }
            }
        }
    }

    return arrow::Status::OK();
}

static void prepare_alias_table(std::int32_t x, std::int32_t y) {
    std::int32_t n_elems = (2 * MAX_JUMP_X + 1) * (2 * MAX_JUMP_Y + 1);
    auto likelihood = stdex::mdspan(&jump_like[x, y, 0, 0], n_elems);
    auto alias_index = stdex::mdspan(&jump_alias_index[x, y, 0, 0], n_elems);
    auto alias_prob = stdex::mdspan(&jump_alias_prob[x, y, 0, 0], n_elems);
    auto small_q = stdex::mdspan(&jump_alias_small_q[x, y, 0, 0], n_elems);
    auto large_q = stdex::mdspan(&jump_alias_large_q[x, y, 0, 0], n_elems);

    std::int32_t small_q_head = 0;
    std::int32_t large_q_head = 0;

    double lhsum = 0;
    for (std::int32_t i = 0; i < n_elems; i++) {
        lhsum += likelihood[i];
    }

    // Everything is too close to zero
    if (lhsum < std::numeric_limits<double>::epsilon()) {
	for (std::int32_t i = 0; i < n_elems; i++) {
	    alias_prob[i] = 1.0;
            likelihood[i] = std::logf(1.0 / n_elems);
	}
	return;
    }

    for (std::int32_t i = 0; i < n_elems; i++) {
        likelihood[i] /= lhsum;
        alias_prob[i] = likelihood[i] * n_elems;
        likelihood[i] = std::logf(likelihood[i]);
        if (alias_prob[i] < 1.0) {
            small_q[small_q_head++] = i;
        } else {
            large_q[large_q_head++] = i;
        }
    }

    while (small_q_head > 0 && large_q_head > 0) {
        auto s = small_q[--small_q_head];
        auto l = large_q[--large_q_head];

        alias_index[s] = l;
        alias_prob[l] = alias_prob[l] + alias_prob[s] - 1.0;

        if (alias_prob[l] < 1.0) {
            small_q[small_q_head++] = l;
        } else {
            large_q[large_q_head++] = l;
        }
    }

    while (large_q_head > 0) {
        auto l = large_q[--large_q_head];
        alias_prob[l] = 1.0;
    }

    while (small_q_head > 0) {
        auto s = small_q[--small_q_head];
        alias_prob[s] = 1.0;
    }
}

static std::pair<std::int32_t, std::int32_t> sample_alias_table(std::int32_t x, std::int32_t y, RngEngine& rng) {
    std::int32_t n_elems = (2 * MAX_JUMP_X + 1) * (2 * MAX_JUMP_Y + 1);
    auto alias_index = stdex::mdspan(&jump_alias_index[x, y, 0, 0], n_elems);
    auto alias_prob = stdex::mdspan(&jump_alias_prob[x, y, 0, 0], n_elems);

    std::int32_t i = sample_discrete(rng, 0, n_elems - 1);
    float p = sample_uniform(rng);

    std::int32_t samp = 0;
    if (p < alias_prob[i]) {
        samp = i;
    } else {
        samp = alias_index[i];
    }

    std::int32_t idx = samp / (2 * MAX_JUMP_Y + 1);
    std::int32_t idy = samp % (2 * MAX_JUMP_Y + 1);
    return std::make_pair(idx, idy);
}

// After prepare_table is called, jump_like contains the log probs
static inline float alias_table_log_prob(std::int32_t idx, std::int32_t idy, std::int32_t x, std::int32_t y) {
    return jump_like[x, y, idx, idy];
}

static void main_loop(H5::H5File& file) {
    std::array<hsize_t, 3> full_dims = {hsize_t(NUM_TICKS), hsize_t(NUM_ROWS), hsize_t(NUM_COLS)};
    auto file_space = H5::DataSpace(full_dims.size(), full_dims.data());

    {% for var in source.tile_data.tile_vars %}
    {% if "save" in var.annots %}
    auto {{ var.name | mangle }}_datatype = {{ var.type.name | h5_type }};
    auto {{ var.name | mangle }}_dataset = file.createDataSet("{{ var.name }}", {{ var.name | mangle }}_datatype, file_space);

    {% endif %}
    {% endfor %}

    for (CUR_TICK = 0; CUR_TICK < NUM_TICKS; CUR_TICK++) {
        fmt::println("tick = {}", CUR_TICK);

	reset_for_tick();

        std::int32_t num_unburned_tick = 0;
        std::int32_t num_burning_tick = 0;
        std::int32_t num_burnt_out_tick = 0;
        std::int32_t num_ember_gen_sum_tick = 0;
        std::int32_t num_ember_recv_sum_tick = 0;

        #pragma omp parallel
        {
            // Create embers
            #pragma omp for reduction(+: num_ember_gen_sum_tick) collapse(2) schedule(guided)
            for (std::int32_t x = 0; x < NUM_ROWS; x++) {
                for (std::int32_t y = 0; y < NUM_COLS; y++) {
                    if ({{ source.tile_data.state_var.name | mangle }}[x, y] == Burning) [[unlikely]] {
                        [[maybe_unused]] Position pos{x, y};

                        // clang-format off
                        float rate = {{ source.fire_model.create_embers.dist.mean | codegen_expr }};
                        // clang-format on
                        rate = std::max<float>(0.0, rate);

                        if (rate > 0.0) {
                            auto count = sample_poisson(thread_state->rng, rate);
                            thread_state->log_prob += poisson_log_prob(count, rate);

                            count = std::min(count, MAX_EMBER_COUNT);
                            num_ember_gen[x, y] = count;
                            num_ember_gen_sum_tick += count;
                        }
                    }
                }
            }

            // Compute jump dist
            #pragma omp for collapse(2) schedule(guided)
            for (std::int32_t sx = 0; sx < NUM_ROWS; sx++) {
                for (std::int32_t sy = 0; sy < NUM_COLS; sy++) {
                    if (num_ember_gen[sx, sy] > 0) [[unlikely]] {
                        for (std::int32_t dxi = 0; dxi < 2 * MAX_JUMP_X + 1; dxi++) {
                            for (std::int32_t dyi = 0; dyi < 2 * MAX_JUMP_Y + 1; dyi++) {
                                std::int32_t dx = sx + dxi - MAX_JUMP_X;
                                std::int32_t dy = sy + dyi - MAX_JUMP_Y;
                                if (is_valid_position(dx, dy)) {
                                    [[maybe_unused]] Position src_pos{sx, sy};
                                    [[maybe_unused]] Position dst_pos{dx, dy};

                                    // clang-format off
                                    float likelihood = {{ source.fire_model.ember_jump_likelihood.like | codegen_expr }};
                                    // clang-format on
                                    likelihood = std::max<float>(0.0, likelihood);

                                    jump_like[sx, sy, dxi, dyi] = likelihood;
                                }
                            }
                        }

                        prepare_alias_table(sx, sy);
                    }
                }
            }

            // Assign embers to receivers
            #pragma omp for reduction(+: num_ember_recv_sum_tick) collapse(2) schedule(guided)
            for (std::int32_t sx = 0; sx < NUM_ROWS; sx++) {
                for (std::int32_t sy = 0; sy < NUM_COLS; sy++) {
                    if (num_ember_gen[sx, sy] > 0) [[unlikely]] {
                        for (std::int32_t ei = 0; ei < num_ember_gen[sx, sy]; ei++) {
                            auto [dxi, dyi] = sample_alias_table(sx, sy, thread_state->rng);
                            thread_state->log_prob += alias_table_log_prob(dxi, dyi, sx, sy);

                            std::int32_t dx = sx + dxi - MAX_JUMP_X;
                            std::int32_t dy = sy + dyi - MAX_JUMP_Y;
                            if (is_valid_position(dx, dy)) {
                                [[maybe_unused]] Position src_pos{sx, sy};
                                [[maybe_unused]] Position dst_pos{dx, dy};

                                // clang-format off
                                float death_prob = {{ source.fire_model.ember_death_prob.prob | codegen_expr }};
                                // clang-format on
                                death_prob = clamp(death_prob, 0.0, 1.0);

                                if (sample_uniform(thread_state->rng) < 1.0 - death_prob) {
                                    #pragma omp atomic update
                                    num_ember_recv[dx, dy] += 1;

                                    num_ember_recv_sum_tick += 1;
                                    thread_state->log_prob += std::logf(1.0 - death_prob);
                                } else {
                                    thread_state->log_prob += std::logf(death_prob);
                                }
                            }
                        }
                    }
                }
            }

            // Do ignition
            #pragma omp for collapse(2) schedule(guided)
            for (std::int32_t x = 0; x < NUM_ROWS; x++) {
                for (std::int32_t y = 0; y < NUM_COLS; y++) {
                    if ({{ source.tile_data.state_var.name | mangle }}[x, y] == Unburned && num_ember_recv[x, y] > 0) [[unlikely]] {
                        [[maybe_unused]] Position pos{x, y};

                        // clang-format off
                        float ignition_prob = {{ source.fire_model.ignition_prob.prob | codegen_expr }};
                        // clang-format on
                        ignition_prob = clamp(ignition_prob, 0.0, 1.0);
                        ignition_prob = 1.0 - std::powf(1.0 - ignition_prob, num_ember_recv[x, y]);

                        if (sample_uniform(thread_state->rng) < ignition_prob) {
                            thread_state->log_prob += std::logf(ignition_prob);

                            float burn_time_mean = {{ source.fire_model.burn_time.dist.mean | codegen_expr }};
                            float burn_time_std = {{ source.fire_model.burn_time.dist.std | codegen_expr }};
                            float burn_time = sample_normal(thread_state->rng);
                            thread_state->log_prob += normal_log_prob(burn_time);

                            burn_time = burn_time * burn_time_mean + burn_time_std;
                            burn_time = std::max<float>(0, burn_time);
                            burn_time = std::roundf(burn_time);

                            {{ source.tile_data.state_var.name | mangle }}[x, y] = Burning;
                            change_time[x, y] = CUR_TICK + burn_time;
                        } else {
                            thread_state->log_prob += std::logf(1.0 - ignition_prob);
                        }
                    }
                }
            }

            // Do transition
            #pragma omp for collapse(2) schedule(guided)
            for (std::int32_t x = 0; x < NUM_ROWS; x++) {
                for (std::int32_t y = 0; y < NUM_COLS; y++) {
                    if (change_time[x, y] == CUR_TICK) [[unlikely]] {
                        {{ source.tile_data.state_var.name | mangle }}[x, y] = BurntOut;
                        change_time[x, y] = -1;
                    }
                }
            }

            #pragma omp for reduction(+:num_unburned_tick, num_burning_tick, num_burnt_out_tick) collapse(2) schedule(guided)
            for (std::int32_t x = 0; x < NUM_ROWS; x++) {
                for (std::int32_t y = 0; y < NUM_COLS; y++) {
                    if ({{ source.tile_data.state_var.name | mangle }}[x, y] == Unburned) {
                        num_unburned_tick++;
                    } else if ({{ source.tile_data.state_var.name | mangle }}[x, y] == Burning) {
                        num_burning_tick++;
                    } else {
                        num_burnt_out_tick++;
                    }
                }
            }

        } // end parallel

        num_unburned[CUR_TICK] = num_unburned_tick;
        num_burning[CUR_TICK] = num_burning_tick;
        num_burnt_out[CUR_TICK] = num_burning_tick;
        num_ember_gen_sum[CUR_TICK] = num_ember_gen_sum_tick;
        num_ember_recv_sum[CUR_TICK] = num_ember_recv_sum_tick;

        std::array<hsize_t, 3> slab_start = {hsize_t(CUR_TICK), 0, 0};
        std::array<hsize_t, 3> slab_count = {1, hsize_t(NUM_ROWS), hsize_t(NUM_COLS)};
        auto mem_space = H5::DataSpace(slab_count.size(), slab_count.data());
        file_space.selectHyperslab(H5S_SELECT_SET, slab_count.data(), slab_start.data());

        {% for var in source.tile_data.tile_vars %}
        {% if "save" in var.annots %}
        {{ var.name | mangle }}_dataset.write(
            {{ var.name | mangle }}.data_handle(),
            {{ var.name | mangle }}_datatype,
            mem_space,
            file_space);

        {% endif %}
        {% endfor %}
    }
}

int main(int argc, char *argv[]) {
    auto main_start_time = Clock::now();

    argparse::ArgumentParser program(argv[0]);
    program.add_description("Fire spread simulator.");

    std::string tile_file_name = "";
    std::string seed_file_name = "";
    std::string tick_file_name = "";
    std::string output_file_name = "";

    {% macro add_argument(short_opt, long_opt, help, var) -%}
    program.add_argument("{{ short_opt }}", "{{ long_opt }}")
	.required()
	.help("{{ help }}")
	.store_into({{ var }});
    {%- endmacro %}

    // clang-format off
    {{ add_argument("-n", "--num-ticks", "Num ticks", "NUM_TICKS") }}

    {{ add_argument("-r", "--num-rows", "Num rows in tile data", "NUM_ROWS") }}

    {{ add_argument("-c", "--num-cols", "Num cols in tile data", "NUM_COLS") }}

    {{ add_argument("-t", "--tile-file", "Tile data file (HDF5).", "tile_file_name") }}

    {{ add_argument("-s", "--seed-file", "Seed data file (HDF5).", "seed_file_name") }}

    {{ add_argument("-w", "--tick-file", "Tick data file (Parquet).", "tick_file_name") }}

    {{ add_argument("-o", "--output-file", "Output file (HDF5).", "output_file_name") }}

    {% for cfg in source.configs %}
    program.add_argument("--config-{{ cfg.name | replace("_", "-") }}")
        .default_value({{ cfg.type.name | cpp_type_config }}({{ cfg.default | codegen_expr }}))
	.help("Config option {{ cfg.name }}.")
	.store_into({{ cfg.name | mangle }});

    {% endfor %}
    // clang-format on

    try {
        program.parse_args(argc, argv);
    } catch (const std::exception& err) {
        std::cerr << err.what() << std::endl;
        std::cerr << program;
        std::exit(1);
    }

    fmt::println("NUM_TICKS = {}", NUM_TICKS);
    fmt::println("NUM_ROWS = {}", NUM_ROWS);
    fmt::println("NUM_COLS = {}", NUM_COLS);
    fmt::println("seed_file_name = {}", seed_file_name);
    fmt::println("tick_file_name = {}", tick_file_name);
    fmt::println("tile_file_name = {}", tile_file_name);
    fmt::println("output_file_name = {}", output_file_name);

    {% for cfg in source.configs %}
    fmt::println("{{ cfg.name }} = {}", {{ cfg.name | mangle }});
    {% endfor %}

    double total_alloc_bytes = 0.0;

    {% macro alloc_tick_var_mem(name, type) %}
    auto {{ name }}_count = NUM_TICKS;
    {{ type }}* {{ name }}_mem = new {{ type  }}[{{ name }}_count];
    auto {{ name  }}_free = stdex::scope_exit([=]() { delete[] {{ name }}_mem; });
    {{ name }} = stdex::mdspan({{ name }}_mem, NUM_TICKS);
    total_alloc_bytes += {{ name }}_count * sizeof({{ type }});
    {% endmacro %}

    {% macro alloc_tile_var_mem(name, type) %}
    auto {{ name }}_count = NUM_ROWS * NUM_COLS;
    {{ type }}* {{ name }}_mem = new {{ type  }}[{{ name }}_count];
    auto {{ name  }}_free = stdex::scope_exit([=]() { delete[] {{ name }}_mem; });
    {{ name }} = stdex::mdspan({{ name }}_mem, NUM_ROWS, NUM_COLS);
    total_alloc_bytes +=  {{ name }}_count * sizeof({{ type }});
    {% endmacro %}

    {% macro alloc_jump_var_mem(name, type) %}
    auto {{ name }}_count = NUM_ROWS * NUM_COLS * (2 * MAX_JUMP_X + 1) * (2 * MAX_JUMP_Y + 1);
    {{ type }}* {{ name }}_mem = new {{ type  }}[{{ name }}_count];
    auto {{ name  }}_free = stdex::scope_exit([=]() { delete[] {{ name }}_mem; });
    {{ name }} = stdex::mdspan({{ name }}_mem, NUM_ROWS, NUM_COLS, 2 * MAX_JUMP_X + 1, 2 * MAX_JUMP_Y + 1);
    total_alloc_bytes +=  {{ name }}_count * sizeof({{ type }});
    {% endmacro %}

    {% for var in source.tick_data.tick_vars %}
    {% if var.is_real %}
    {{ alloc_tick_var_mem(var.name | mangle, var.type.name | cpp_type) }}

    {% endif %}
    {% endfor %}

    {% for var in source.tile_data.tile_vars %}
    {% if var.is_real %}
    {{ alloc_tile_var_mem(var.name | mangle, var.type.name | cpp_type) }}

    {% endif %}
    {% endfor %}

    {{ alloc_tile_var_mem("change_time", "std::int32_t") }}

    {{ alloc_tile_var_mem("num_ember_gen", "std::int32_t") }}

    {{ alloc_tile_var_mem("num_ember_recv", "std::int32_t") }}

    {{ alloc_jump_var_mem("jump_like", "float") }}

    {{ alloc_jump_var_mem("jump_alias_index", "std::int32_t",) }}

    {{ alloc_jump_var_mem("jump_alias_prob", "float") }}

    {{ alloc_jump_var_mem("jump_alias_small_q", "std::int32_t") }}

    {{ alloc_jump_var_mem("jump_alias_large_q", "std::int32_t") }}

    {{ alloc_tick_var_mem("num_unburned", "std::int32_t") }}

    {{ alloc_tick_var_mem("num_burning", "std::int32_t") }}

    {{ alloc_tick_var_mem("num_burnt_out", "std::int32_t") }}

    {{ alloc_tick_var_mem("num_ember_gen_sum", "std::int32_t") }}

    {{ alloc_tick_var_mem("num_ember_recv_sum", "std::int32_t") }}

    fmt::println("total_alloc_gb = {}", total_alloc_bytes / 1e9);

    std::random_device rnd_device;
    auto seed = rnd_device();
    #pragma omp parallel
    {
        #pragma omp critical
        {
            thread_state = new ThreadState();
            thread_state->rng = RngEngine({ {seed, unsigned(omp_get_thread_num())} });
            thread_state->log_prob = 0.0;
        }
    }
    auto thread_state_free = stdex::scope_exit([=]() {
        #pragma omp parallel
        {
            #pragma omp critical
            {
                delete thread_state;
            }
        }
    });

    auto init_start_time = Clock::now();
    initialize_memory();

    load_tile_data(tile_file_name);
    load_seed_data(seed_file_name);
    auto status = load_tick_data(tick_file_name);
    if (!status.ok()) {
        throw std::runtime_error(fmt::format("Failed to read tick data: {}", status.ToString()));
    }

    double init_duration = Duration(Clock::now() - init_start_time).count();

    H5::H5File output_file(output_file_name, H5F_ACC_CREAT | H5F_ACC_RDWR);

    auto main_loop_start_time = Clock::now();
    main_loop(output_file);
    double main_loop_duration = Duration(Clock::now() - main_loop_start_time).count();

    {% macro save_tick_stat(name, h5_type) %}
    {
        std::array<hsize_t, 1> dims = {hsize_t(NUM_TICKS)};
        auto dataspace = H5::DataSpace(dims.size(), dims.data());
        auto datatype = {{ h5_type }};
        auto dataset = output_file.createDataSet("{{ name }}", datatype, dataspace);
        dataset.write({{ name }}.data_handle(), datatype);
    }
    {% endmacro %}

    {{ save_tick_stat("num_unburned", "H5::PredType::NATIVE_INT32") }}

    {{ save_tick_stat("num_burning", "H5::PredType::NATIVE_INT32") }}

    {{ save_tick_stat("num_burnt_out", "H5::PredType::NATIVE_INT32") }}

    {{ save_tick_stat("num_ember_gen_sum", "H5::PredType::NATIVE_INT32") }}

    {{ save_tick_stat("num_ember_recv_sum", "H5::PredType::NATIVE_INT32") }}

    double log_prob = 0.0;
    #pragma omp parallel reduction(+: log_prob)
    {
        log_prob += thread_state->log_prob;
    }
    fmt::println("log_prob = {}", log_prob);

    double main_duration = Duration(Clock::now() - main_start_time).count();
    fmt::println("main_duration_s = {}", main_duration);

    {% macro save_run_stat(name, var_name, h5_type) %}
    {
        auto dataspace = H5::DataSpace(H5S_SCALAR);
        auto datatype = {{ h5_type }};
        auto attribute = output_file.createAttribute("{{ name }}", datatype, dataspace);
        attribute.write(datatype, &{{ var_name }});
    }
    {% endmacro %}

    {{ save_run_stat("main_duration_s", "main_duration", "H5::PredType::NATIVE_DOUBLE") }}

    {{ save_run_stat("init_duration_s", "init_duration", "H5::PredType::NATIVE_DOUBLE") }}

    {{ save_run_stat("main_loop_duration_s", "main_loop_duration", "H5::PredType::NATIVE_DOUBLE") }}

    {{ save_run_stat("total_alloc_bytes", "total_alloc_bytes", "H5::PredType::NATIVE_DOUBLE") }}

    {{ save_run_stat("log_prob", "log_prob", "H5::PredType::NATIVE_DOUBLE") }}

    return 0;
}

