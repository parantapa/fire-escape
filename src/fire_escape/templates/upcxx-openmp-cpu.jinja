#include <cstdint>
#include <experimental/scope>

#include <spdlog/spdlog.h>
#include <argparse/argparse.hpp>

#include <omp.h>
#include <upcxx/upcxx.hpp>

#include "chunk_utils.hpp"
#include "simulator_utils.hpp"

namespace stdex = std::experimental;

void parse_arguments(int argc, char *argv[]) {
    argparse::ArgumentParser program(argv[0]);
    program.add_description("Fire spread simulator.");

    {% macro add_argument(short_opt, long_opt, help, var) -%}
    program.add_argument("{{ short_opt }}", "{{ long_opt }}")
	.required()
	.help("{{ help }}")
	.store_into({{ var }});
    {%- endmacro %}

    // clang-format off
    {{ add_argument("-n", "--num-ticks", "Num ticks", "NUM_TICKS") }}
    {{ add_argument("-bx", "--begin-x", "Starting x coordinate (inclusive).", "WORLD_REGION.begin.x") }}
    {{ add_argument("-ex", "--end-x", "Ending x coordinate (exclusive).", "WORLD_REGION.end.x") }}
    {{ add_argument("-by", "--begin-y", "Starting y coordinate (inclusive).", "WORLD_REGION.begin.y") }}
    {{ add_argument("-ey", "--end-y", "Ending y coordinate (exclusive).", "WORLD_REGION.end.y") }}
    {{ add_argument("-t", "--tile-file", "Tile data file (HDF5).", "TILE_FILE_NAME") }}
    {{ add_argument("-s", "--seed-file", "Seed data file (HDF5).", "SEED_FILE_NAME") }}
    {{ add_argument("-w", "--tick-file", "Tick data file (Parquet).", "TICK_FILE_NAME") }}
    {{ add_argument("-o", "--output-file", "Output file (HDF5).", "OUTPUT_FILE_NAME") }}
    // clang-format on

    try {
        program.parse_args(argc, argv);
    } catch (const std::exception& err) {
        if (upcxx::rank_me() == 0) {
            std::cerr << err.what() << std::endl;
            std::cerr << program;
        }
        std::exit(1);
    }

    if (upcxx::rank_me() == 0) {
        spdlog::info("NUM_TICKS = {}", NUM_TICKS);
        spdlog::info("X_RANGE = [{}, {})", WORLD_REGION.begin.x, WORLD_REGION.end.x);
        spdlog::info("Y_RANGE = [{}, {})", WORLD_REGION.begin.y, WORLD_REGION.end.y);
        spdlog::info("SEED_FILE_NAME = {}", SEED_FILE_NAME);
        spdlog::info("TICK_FILE_NAME = {}", TICK_FILE_NAME);
        spdlog::info("TILE_FILE_NAME = {}", TILE_FILE_NAME);
        spdlog::info("OUTPUT_FILE_NAME = {}", OUTPUT_FILE_NAME);
    }
}

int main(int argc, char* argv[]) {
    upcxx::init();
    auto upcxx_finalize_guard = stdex::scope_exit([](){ upcxx::finalize(); });

    setup_spdlog();
    parse_arguments(argc, argv);

    // initialize data structures
    hash_set<Vector2> owned_chunks;
    OWNED_CHUNKS = &owned_chunks;
    
    hash_map<Vector2, ChunkInfo> chunk_info;
    CHUNK_INFO = &chunk_info;

    // load data
    populate_local_chunks();

    for (int i = 0; i < upcxx::rank_n(); i++) {
        upcxx::barrier();
        if (i == upcxx::rank_me()) {
            for (const auto& [_, chunk_info]: chunk_info) {
                spdlog::info("{}", chunk_info);
            }
        }
    }


    // for (CUR_TICK = 0; CUR_TICK < NUM_TICKS; CUR_TICK++) {
    //     upcxx::barrier();

    //     if (upcxx::rank_me() == 0) {
    //         spdlog::info("Starting tick: {}", CUR_TICK);
    //     }
    // };

    return 0;
}
