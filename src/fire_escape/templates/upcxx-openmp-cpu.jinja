          OpenMP::OpenMP_CXX)
target_compile_features(simulator PRIVATE cxx_std_23)

{#- name: "conanfile.py" -#}
# type: ignore
from conan import ConanFile
from conan.tools.cmake import cmake_layout, CMakeDeps, CMakeToolchain, CMake


class FireEscapeSimRecipe(ConanFile):
    name = "fire-escape-sim"
    settings = "os", "compiler", "build_type", "arch"

    def layout(self):
        cmake_layout(self)

    def requirements(self):
        self.requires("fmt/12.1.0")
        self.requires("spdlog/1.17.0")
        self.requires("argparse/3.2")
        self.requires("xxhash/0.8.3")
        self.requires("parallel-hashmap/2.0.0")
        self.requires("cista/0.16")
        self.requires("arrow/23.0.1")
        self.requires("hdf5/1.14.6")
        self.requires("upcxx/2025.10.0.pci")

    def generate(self):
        deps = CMakeDeps(self)
        deps.generate()

        toolchain = CMakeToolchain(self)
        toolchain.generate()

    def build(self):
        cmake = CMake(self)
        cmake.configure()
        cmake.build()
