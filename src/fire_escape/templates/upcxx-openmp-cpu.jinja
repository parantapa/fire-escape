#include <experimental/scope>

#include <spdlog/spdlog.h>
#include <argparse/argparse.hpp>
#include <xxhash.h>
#include <parallel_hashmap/phmap.h>

#include <omp.h>
#include <upcxx/upcxx.hpp>

namespace stdex = std::experimental;

template<typename K>
using flat_hash_set = phmap::flat_hash_set<K>;

template<typename K, typename V>
using flat_hash_map = phmap::flat_hash_map<K, V>;

{% for opt in source.options %}
constexpr std::int32_t {{ opt.name | upper }} = {{ opt.value }};
{% endfor %}

using fire_state_t = std::int8_t;
constexpr fire_state_t Unburned = 0;
constexpr fire_state_t Burning = 1;
constexpr fire_state_t BurntOut = 2;

static std::int32_t NUM_TICKS = 0;

static std::int32_t BEGIN_PX = 0;
static std::int32_t END_PX = 0;
static std::int32_t BEGIN_PY = 0;
static std::int32_t END_PY = 0;

static inline std::int32_t clamp_px(std::int32_t px) {
    if (px < BEGIN_PX) { px = BEGIN_PX; }
    if (px > END_PX - 1) { px = END_PX; }
    return px;
}

static inline std::int32_t clamp_py(std::int32_t py) {
    if (py < BEGIN_PY) { py = BEGIN_PY; }
    if (py > END_PY - 1) { py = END_PY; }
    return py;
}

struct Position {
    std::int32_t px;
    std::int32_t py;

    bool operator==(const Position&) const = default;
};

struct Chunk {
    std::int32_t cx;
    std::int32_t cy;

    bool operator==(const Chunk&) const = default;

    Chunk north() const noexcept { return {cx, cy - 1}; }
    Chunk south() const noexcept { return {cx, cy + 1}; }
    Chunk east() const noexcept { return {cx + 1, cy}; }
    Chunk west() const noexcept { return {cx - 1, cy}; }
    Chunk north_east() const noexcept { return {cx + 1, cy - 1}; }
    Chunk north_west() const noexcept { return {cx - 1, cy - 1}; }
    Chunk south_east() const noexcept { return {cx + 1, cy + 1}; }
    Chunk south_west() const noexcept { return {cx - 1, cy + 1}; }

    Position begin() const noexcept {
        std::int32_t px = clamp_px(cx * CHUNK_SIZE_X);
        std::int32_t py = clamp_py(cy * CHUNK_SIZE_Y);
        return {px, py};
    }

    Position end() const noexcept {
        return Chunk{cx + 1, cy + 1}.begin();
    }

    std::int32_t size() const noexcept {
        auto begin_ = begin();
        auto end_ = end();
        return (end_.px - begin_.px) * (end_.py - begin_.py);
    }

    std::int32_t to_offset(const Position position) const noexcept {
        auto begin_ = begin();
        auto end_ = end();
        auto ystride = (end_.px - begin_.px);

        auto dx = position.px - begin_.px;
        auto dy = position.py - begin_.py;
        return dy * ystride + dx;
    }

    Position to_position(const std::int32_t offset) const noexcept {
        auto begin_ = begin();
        auto end_ = end();
        auto ystride = (end_.px - begin_.px);

        auto dx = offset % ystride;
        auto dy = (offset - dx) / ystride;
        return {begin_.px + dx, begin_.py + dy};
    }

    bool is_valid() const noexcept {
        std::int32_t cx_begin = BEGIN_PX / CHUNK_SIZE_X;
        std::int32_t cx_end = END_PX / CHUNK_SIZE_X;
        std::int32_t cy_begin = BEGIN_PY / CHUNK_SIZE_Y;
        std::int32_t cy_end = END_PY / CHUNK_SIZE_Y;

        return (cx >= cx_begin && cx < cx_end && cy >= cy_begin && cy < cy_end);
    }

    XXH64_hash_t hash() const noexcept {
        std::uint64_t buf = std::uint64_t(cx) << 32 | std::uint64_t(cy);
        return XXH64(&buf, sizeof(std::uint64_t), 0);
    }

    upcxx::intrank_t owner_rank() const {
        return hash() % upcxx::rank_n();
    }
};

template<> struct std::hash<Chunk> {
    std::size_t operator()(Chunk const& chunk) const noexcept {
        return chunk.hash();
    }
};

static inline Chunk get_chunk(const Position position) {
    return {position.px / CHUNK_SIZE_X, position.py / CHUNK_SIZE_Y};
}

template<typename Type>
struct TileChunkData {
    Chunk chunk;
    upcxx::global_ptr<Type> lptr;
    upcxx::global_ptr<Type> rptr;

    TileChunkData()
        : chunk{}
        , lptr{nullptr}
        , rptr{nullptr} {}


    TileChunkData(const Chunk chunk_)
        : chunk{chunk_}
        , lptr{nullptr}
        , rptr{nullptr} {
        lptr = upcxx::new_array<Type>(chunk.size());
    }

    TileChunkData(const TileChunkData&) = delete;

    TileChunkData(TileChunkData&& other) noexcept
        : chunk{std::move(other.chunk)}
        , lptr{std::move(other.lptr)}
        , rptr{std::move(other.rptr)} {
            other.lptr = nullptr;
            other.rptr = nullptr;
        }

    TileChunkData& operator=(const TileChunkData&) = delete;

    TileChunkData& operator=(TileChunkData&& other) noexcept {
        if (!lptr.is_null()) {
            upcxx::delete_array(lptr);
        }

        chunk = std::move(other.chunk);
        lptr = std::move(other.lptr);
        rptr = std::move(other.rptr);

        other.lptr = nullptr;
        other.rptr = nullptr;

        return *this;
    }

    ~TileChunkData() {
        if (!lptr.is_null()) {
            upcxx::delete_array(lptr);
            lptr = nullptr;
            rptr = nullptr;
        }
    }
};

static inline std::vector<Chunk>* LOCAL_CHUNKS = nullptr;
static inline std::vector<Chunk>* REMOTE_CHUNKS = nullptr;
static inline flat_hash_set<Chunk>* AVAILABLE_CHUNKS = nullptr;

