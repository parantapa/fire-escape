        auto mem_type = {{ var.type.name | h5_type }};
        auto dataset = file.openDataSet("{{ var.name }}");
        dataset.read({{ var.name | mangle }}.data_handle(), mem_type, mem_space, file_space);
    }

    {% endif %}
    {% endfor %}
}

