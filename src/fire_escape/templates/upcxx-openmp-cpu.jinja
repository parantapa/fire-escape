{% endif %}
{% endfor %}

{% for name, type in tile_vars %}
static flat_hash_map<Chunk, TileChunkData<{{ type }}>>* {{ name }} = nullptr;
{% endfor %}

int main(int argc, char* argv[]) {
    argparse::ArgumentParser program(argv[0]);
    program.add_description("Fire spread simulator.");

    std::string tile_file_name = "";
    std::string seed_file_name = "";
    std::string tick_file_name = "";
    std::string output_file_name = "";

    // clang-format off
    program.add_argument("-n", "--num-ticks")
	.required()
	.help("Num ticks")
	.store_into(NUM_TICKS);
    program.add_argument("-bx", "--begin-x")
        .required()
	.help("Tile data X range begin.")
	.store_into(BEGIN_PX);
    program.add_argument("-by", "--begin-y")
        .required()
	.help("Tile data Y range begin.")
	.store_into(BEGIN_PY);
    program.add_argument("-ex", "--end-x")
	.required()
	.help("Tile data X range end.")
	.store_into(END_PX);
    program.add_argument("-ey", "--end-y")
	.required()
	.help("Tile data Y range end.")
	.store_into(END_PY);
    program.add_argument("-t", "--tile-file")
	.required()
	.help("Tile data file (HDF5).")
	.store_into(tile_file_name);
    program.add_argument("-s", "--seed-file")
	.required()
	.help("Seed data file (HDF5).")
	.store_into(seed_file_name);
    program.add_argument("-w", "--tick-file")
	.required()
	.help("Tick data file (Parquet).")
	.store_into(tick_file_name);
    program.add_argument("-o", "--output-file")
	.required()
	.help("Output file (HDF5).")
	.store_into(output_file_name);
    // clang-format on

    try {
        program.parse_args(argc, argv);
    } catch (const std::exception& err) {
        std::cerr << err.what() << std::endl;
        std::cerr << program;
        std::exit(1);
    }

    upcxx::init();
    auto upcxx_finalize = stdex::scope_exit([]() { upcxx::finalize(); });
    spdlog::set_pattern(fmt::format("{}/{}: %v", upcxx::rank_me(), upcxx::rank_n()));

    if (upcxx::rank_me() == 0) {
        spdlog::info("NUM_TICKS = {}", NUM_TICKS);
        spdlog::info("X_RANGE = [{},{})", BEGIN_PX, END_PX);
        spdlog::info("Y_RANGE = [{},{})", BEGIN_PY, END_PY);
        spdlog::info("seed_file_name = {}", seed_file_name);
        spdlog::info("tick_file_name = {}", tick_file_name);
        spdlog::info("tile_file_name = {}", tile_file_name);
        spdlog::info("output_file_name = {}", output_file_name);
    }

    std::vector<Chunk> local_chunks;
    std::vector<Chunk> remote_chunks;
    flat_hash_set<Chunk> available_chunks;

    for (std::int32_t py = BEGIN_PY; py < END_PY; py += CHUNK_SIZE_Y) {
        for (std::int32_t px = BEGIN_PX; px < END_PX; px += CHUNK_SIZE_X) {
            Chunk chunk = get_chunk({px, py});
            if (chunk.owner_rank() == upcxx::rank_me()) {
                local_chunks.push_back(chunk);
                available_chunks.insert(chunk);
            }
        }
    }
    for (const auto& chunk: local_chunks) {
        const Chunk adjacent_chunks[] = {
            chunk.north(),
            chunk.south(),
            chunk.east(),
            chunk.west(),
            chunk.north_east(),
            chunk.north_west(),
            chunk.south_east(),
            chunk.south_west(),
        };
        for (const auto& achunk: adjacent_chunks) {
            if (achunk.is_valid() && !available_chunks.contains(achunk)) {
                remote_chunks.push_back(achunk);
                available_chunks.insert(achunk);
            }
        }
    }

    spdlog::info("num_local_chunks = {}", local_chunks.size());
    spdlog::info("num_remote_chunks = {}", remote_chunks.size());
    spdlog::info("num_available_chunks = {}", available_chunks.size());

    LOCAL_CHUNKS = &local_chunks;
    REMOTE_CHUNKS = &remote_chunks;
    AVAILABLE_CHUNKS = &available_chunks;

    {% for name, type in tile_vars %}
    flat_hash_map<Chunk, TileChunkData<{{ type }}>> {{ name }}_chunk_data;
    for (const auto& chunk: available_chunks) {
            {{ name }}_chunk_data.insert({ chunk, TileChunkData<{{ type }}>(chunk) });
    }
    {{ name }} = &{{ name }}_chunk_data;
    {% endfor %}

    return 0;
}

