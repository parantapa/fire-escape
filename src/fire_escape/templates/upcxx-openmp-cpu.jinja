static void load_tile_data(const std::string& file_name) {
    H5::H5File file = H5::H5File(file_name, H5F_ACC_RDONLY);

    std::array<hsize_t, 2> full_dims = {hsize_t(NUM_ROWS), hsize_t(NUM_COLS)};
    auto file_space = H5::DataSpace(full_dims.size(), full_dims.data());

    std::array<hsize_t, 2> slab_start = {hsize_t(ROW_BEGIN_LOCAL), hsize_t(COL_BEGIN_LOCAL)};
    std::array<hsize_t, 2> slab_count = {hsize_t(NUM_ROWS_LOCAL), hsize_t(NUM_COLS_LOCAL)};
    auto mem_space = H5::DataSpace(slab_count.size(), slab_count.data());
    file_space.selectHyperslab(H5S_SELECT_SET, slab_count.data(), slab_start.data());

    {% for var in source.tile_data.tile_vars %}
