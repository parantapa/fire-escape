        {% for name, _ in tile_vars %}
        #pragma omp for simd collapse(2) schedule(static) nowait
        for (std::int32_t x = 0; x < NUM_ROWS_LOCAL; x++) {
            for (std::int32_t y = 0; y < NUM_COLS_LOCAL; y++) {
                {{ name }}[x, y] = 0;
