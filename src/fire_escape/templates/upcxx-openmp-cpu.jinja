static inline Position to_local_index(Position pos) {
    return Position{
        .x = pos.x - ROW_BEGIN_LOCAL,
        .y = pos.y - COL_BEGIN_LOCAL
    };
}

static inline bool is_local_position(Position pos) {
    return (
        pos.x >= ROW_BEGIN_LOCAL &&
        pos.x < ROW_END_LOCAL &&
        pos.y >= COL_BEGIN_LOCAL &&
        pos.y < COL_END_LOCAL
    );
}

static inline bool is_internal_position(Position pos) {
    return (
        pos.x >= ROW_BEGIN_INTERNAL &&
        pos.x < ROW_END_INTERNAL &&
        pos.y >= COL_BEGIN_INTERNAL &&
        pos.y < COL_END_INTERNAL
    );
}

static inline bool is_left_position(Position pos) {
    return (
        pos.x >= ROW_BEGIN_LEFT &&
        pos.x < ROW_END_LEFT &&
        pos.y >= COL_BEGIN_LEFT &&
        pos.y < COL_END_LEFT
    );
}

static inline bool is_right_position(Position pos) {
    return (
        pos.x >= ROW_BEGIN_RIGHT &&
        pos.x < ROW_END_RIGHT &&
        pos.y >= COL_BEGIN_RIGHT &&
        pos.y < COL_END_RIGHT
    );
}

